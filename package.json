{
  "name": "rpgsu-layouts",
  "version": "1.0.0",
  "scripts": {
    "autofix": "run-s autofix:*",
    "autofix:browser": "eslint --fix --ext .ts,.tsx src/browser",
    "autofix:extension": "eslint --fix --ext .ts src/extension && eslint --fix --ext .d.ts src/nodecg",
    "build": "run-s clean build:*",
    "build:browser": "vite build",
    "build:extension": "tsc -b tsconfig.extension.json",
    "clean": "trash node_modules/.cache && trash shared/dist && trash dashboard && trash graphics && trash extension",
    "lint": "eslint src/browser src/extension --report-unused-disable-directives --max-warnings 0",
    "prebuild": "pnpm clean",
    "postinstall": "node install-submodules.js",
    "schema-types": "nodecg schema-types -o src/types/generated",
    "start": "nodecg start",
    "watch": "run-p watch:*",
    "watch:browser": "vite",
    "watch:extension": "tsc -b tsconfig.extension.json -w --preserveWatchOutput"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@fontsource/roboto": "^5.0.3",
    "@mui/material": "^7.3.8",
    "@nodecg/react-hooks": "^1.0.3",
    "@tailwindcss/vite": "^4.1.12",
    "auto-text-size": "^0.2.3",
    "humanize-duration": "^3.33.2",
    "json-schema-to-typescript": "^15.0.4",
    "luxon": "^3.7.2",
    "motion": "^12.38.0",
    "nodecg": "^2.6.1",
    "obs-websocket-js": "^5.0.6",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-icons": "^5.5.0",
    "react-is": "18.2.0",
    "tailwindcss": "^4.1.12",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@rpgsu/lint-config": "^1.0.1",
    "@types/humanize-duration": "^3.27.4",
    "@types/lodash": "^4.14.195",
    "@types/luxon": "^3.7.1",
    "@types/node": "^24.8.1",
    "@types/react": "^18.0.37",
    "@types/react-dom": "^18.0.11",
    "@vitejs/plugin-react": "^4.3.2",
    "cheerio": "1.0.0-rc.12",
    "del": "^7.0.0",
    "del-cli": "^5.0.0",
    "get-port": "^7.0.0",
    "globals": "^15.10.0",
    "globby": "^13.1.4",
    "nodecg-cli": "^8.6.6",
    "npm-run-all": "^4.1.5",
    "rollup": "^3.25.1",
    "trash-cli": "^5.0.0",
    "typescript": "^5.6.2",
    "vite": "^7.1.4",
    "vite-plugin-checker": "^0.8.0"
  },
  "overrides": {
    "react-is": "^18.2.0"
  },
  "nodecg": {
    "compatibleRange": "^2.0.0",
    "dashboardPanels": [
      {
        "file": "next-run.html",
        "name": "next-run",
        "title": "Switch to next run",
        "width": 2
      },
      {
        "file": "game-layout-override.html",
        "name": "game-layout-override",
        "title": "Layout Override",
        "width": 2,
        "workspace": "Scene Editing"
      },
      {
        "file": "camera-and-comms.html",
        "name": "camera-and-comms",
        "title": "Layout Information",
        "width": 3
      },
      {
        "file": "tech-setup-checklist.html",
        "name": "tech-setup-checklist",
        "title": "Checklist",
        "width": 3
      },
      {
        "file": "flashing-lights-warning.html",
        "name": "lashing-lights-warning",
        "title": "Flashing Lights Warning",
        "width": 2,
        "workspace": "Scene Editing"
      },
      {
        "file": "omnibar-config.html",
        "name": "omnibar-config",
        "title": "Omnibar Config",
        "width": 3
      }
    ],
    "graphics": [
      {
        "file": "intermission.html",
        "width": 1920,
        "height": 1020
      },
      {
        "file": "game.html",
        "width": 1920,
        "height": 1020
      },
      {
        "file": "omnibar.html",
        "width": 1920,
        "height": 60
      }
    ]
  },
  "packageManager": "pnpm@10.28.0+sha512.05df71d1421f21399e053fde567cea34d446fa02c76571441bfc1c7956e98e363088982d940465fd34480d4d90a0668bc12362f8aa88000a64e83d0b0e47be48"
}
