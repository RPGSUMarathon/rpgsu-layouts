{
  "compilerOptions": {
    "module": "ES2022",
    "target": "ES2022",
    "moduleResolution": "bundler",
    "lib": [
      "ES2022",
      "DOM",
      "es5",
      "es6",
      "dom",
      "dom.iterable"
    ],
    "types": [
      "node"
    ],
    "sourceMap": true,
    "importHelpers": false,
    "resolveJsonModule": true,
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": false, // TODO: enable this
    "noPropertyAccessFromIndexSignature": false,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "isolatedModules": true,
    "baseUrl": ".",
    "paths": {
      "speedcontrol/*": [
        "bundles/nodecg-speedcontrol/*"
      ],
      "foobar2000-controller/*": [
        "bundles/nodecg-foobar2000-controller/*"
      ],
      "@rpgsu-layouts/*": [
        "src/*",
        "src/graphics/*",
        "src/dashboard/*"
      ],
      "@rpgsu-layouts/types": [
        "src/types"
      ],
      "@rpgsu-layouts/types/*": [
        "src/types/*"
      ]
    }
  }
}
